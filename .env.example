# redflag-check environment variables
# ------------------------------------------------------------------------------
# Copy this file to `.env` (which is gitignored) for local `vercel dev`, AND add
# the same values to the Vercel project for production:
#   Vercel dashboard -> Settings -> Environment Variables, or `vercel env add`.
# The local `.env` is NOT read by the deployed site.

# Optional. NWS api.weather.gov wants a real contact in the User-Agent.
NWS_CONTACT_EMAIL=

# Optional. Geoapify Static Maps API key (free tier, no credit card).
# When set, zone-check results upgrade the SVG polygon to a real basemap image,
# loaded directly in the browser. The key is therefore PUBLIC by design — restrict
# it to your domain in the Geoapify dashboard and rely on the free-tier cap.
# If unset (or if the image fails to load), the UI falls back to the SVG polygon.
GEOAPIFY_API_KEY=
